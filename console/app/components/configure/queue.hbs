<ContentPanel @title={{t "component.configure.queue.title"}} @open={{true}} @wrapperClass="bordered-classic">
    <InputGroup @name={{t "component.configure.queue.driver"}} @helpText={{t "component.configure.queue.driver-help-text"}}>
        <Select @options={{this.connections}} @value={{this.driver}} @onSelect={{this.setDriver}} @placeholder={{t "component.configure.queue.select-driver"}} disabled={{this.isLoading}} class="w-full" />
    </InputGroup>
    {{#if (eq this.driver "beanstalkd")}}
        <InputGroup @name={{t "component.configure.queue.beanstalk-host"}} @value={{this.beanstalkdHost}} disabled={{this.isLoading}} />
        <InputGroup @name={{t "component.configure.queue.beanstalk-queue"}} @value={{this.beanstalkdQueue}} />
    {{/if}}
    {{#if (eq this.driver "sqs")}}
        <InputGroup @name={{t "component.configure.queue.sqs-prefix"}} @value={{this.sqsPrefix}} disabled={{this.isLoading}} />
        <InputGroup @name={{t "component.configure.queue.sqs-queue"}} @value={{this.sqsQueue}} disabled={{this.isLoading}} />
        <InputGroup @name={{t "component.configure.queue.sqs-suffix"}} @value={{this.sqsSuffix}} disabled={{this.isLoading}} />
    {{/if}}
    {{#if this.testResponse}}
        <div class="flex flex-row items-center rounded-lg border {{if (eq this.testResponse.status 'error') 'border-red-900 bg-red-800 text-red-100' 'border-green-900 bg-green-800 text-green-100'}} shadow-sm my-2 px-4 py-2">
            <FaIcon @icon={{if (eq this.testResponse.status 'error') 'triangle-exclamation' 'circle-check'}} class="mr-1.5 {{if (eq this.testResponse.status 'error') 'text-red-200' 'text-green-200'}}" />
            <span class="text-xs">{{this.this.testResponse.message}}</span>
        </div>
    {{/if}}
    <Button @wrapperClass="mt-3" @icon="plug" @text={{t "component.configure.test-config"}} @onClick={{this.test}} @isLoading={{this.isLoading}} />
</ContentPanel>

<EmberWormhole @to="next-view-section-subheader-actions">
    <Button @type="primary" @size="sm" @icon="save" @text={{t "component.configure.save-changes"}} @onClick={{this.save}} @disabled={{this.isLoading}} @isLoading={{this.isLoading}} />
</EmberWormhole>
